# restore.py - Konfiguration. Kopie als `.env` anlegen und anpassen.
# .env wird nicht committet (siehe .gitignore). Gesetzte Shell-Env-Vars
# haben Vorrang vor .env.

# Backup-Wurzel (Default: ~/.restore_backups). Absoluter oder relativer
# Pfad. Beispiel Windows:
# RESTORE_BACKUP_ROOT=C:\Users\<user>\restore_backups
# Beispiel POSIX:
# RESTORE_BACKUP_ROOT=/home/<user>/restore_backups

# Projekt-Unterordner-Name (Default: Basename des aktuellen Verzeichnisses).
# Nur setzen bei Namens-Kollision gleichnamiger Projekte.
# RESTORE_PROJECT_NAME=mein-projekt
